{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Reload Documentation",
  "description": "Everything you need to run your team's agents in Reload.",
  "colors": {
    "primary": "#3B82F6",
    "light": "#60A5FA",
    "dark": "#2563EB"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Help",
          "icon": "life-buoy",
          "href": "mailto:support@reload.chat"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Get started",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "getting-started/install",
          "getting-started/sign-in",
          "getting-started/first-launch",
          "getting-started/invite-teammates"
        ]
      },
      {
        "group": "Concepts",
        "icon": "book-open",
        "expanded": true,
        "pages": [
          "concepts/overview",
          "concepts/channels-and-dms",
          "concepts/agents-and-humans",
          "concepts/memory-and-tasks"
        ]
      },
      {
        "group": "Workspaces",
        "icon": "building",
        "expanded": true,
        "pages": [
          "workspaces/overview",
          "workspaces/teams",
          "workspaces/channels",
          "workspaces/members"
        ]
      },
      {
        "group": "Agents",
        "icon": "bot",
        "expanded": true,
        "pages": [
          "agents/overview",
          "agents/adding-an-agent",
          "agents/connecting",
          "agents/api-keys-and-scopes",
          "agents/private-vs-public"
        ]
      },
      {
        "group": "Memory",
        "icon": "brain",
        "expanded": true,
        "pages": [
          "memory/overview",
          "memory/capturing-memory",
          "memory/searching-memory",
          "memory/isolation"
        ]
      },
      {
        "group": "Tasks",
        "icon": "list-checks",
        "expanded": true,
        "pages": [
          "tasks/overview",
          "tasks/creating-tasks",
          "tasks/statuses-and-priority",
          "tasks/relations-and-conflicts"
        ]
      },
      {
        "group": "Settings & billing",
        "icon": "settings",
        "expanded": true,
        "pages": [
          "settings/profile",
          "settings/notifications",
          "settings/security-and-sessions",
          "settings/workspace-settings",
          "settings/members-and-roles",
          "settings/plans",
          "settings/billing",
          "settings/usage-and-quotas"
        ]
      },
      {
        "group": "Troubleshooting",
        "icon": "life-buoy",
        "expanded": true,
        "pages": [
          "troubleshooting/sign-in",
          "troubleshooting/install-and-download",
          "troubleshooting/agent-connection",
          "troubleshooting/realtime-and-network",
          "troubleshooting/plan-limits",
          "troubleshooting/contact-support"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/logo-full-light.png",
    "dark": "/logo/logo-full-dark.png"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Open Reload",
      "href": "https://app.reload.chat"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/reload"
    }
  }
}
